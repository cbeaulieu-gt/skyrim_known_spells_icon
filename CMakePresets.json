{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 23,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "base-windows",
      "hidden": true,
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_TOOLCHAIN_FILE": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
        "VCPKG_TARGET_TRIPLET": "x64-windows-static-md"
      }
    },
    {
      "name": "vs2022-ae-debug",
      "inherits": "base-windows"
    },
    {
      "name": "vs2022-ae-release",
      "inherits": "base-windows"
    },
    {
      "name": "vs2022-se-debug",
      "inherits": "base-windows"
    },
    {
      "name": "vs2022-se-release",
      "inherits": "base-windows"
    }
  ],
  "buildPresets": [
    {
      "name": "build-ae-debug",
      "configurePreset": "vs2022-ae-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-ae-release",
      "configurePreset": "vs2022-ae-release",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "build-se-debug",
      "configurePreset": "vs2022-se-debug",
      "configuration": "Debug"
    },
    {
      "name": "build-se-release",
      "configurePreset": "vs2022-se-release",
      "configuration": "RelWithDebInfo"
    }
  ]
}
