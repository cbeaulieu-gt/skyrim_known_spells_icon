# Copy this file to .env and set your local deployment destination.
# The deploy script reads this when -TargetDir is not provided.
DEPLOY_TARGET_DIR=I:/games/skyrim/mods/MyMod/SKSE/Plugins

# Optional: semicolon- or comma-separated directories where -CreateZip output
# should be copied.
# Example:
# DEPLOY_ZIP_TARGET_DIRS=I:/games/skyrim/mods/MyMod;I:/archives/skyrim
DEPLOY_ZIP_TARGET_DIRS=
